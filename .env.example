# ─── Notion ───────────────────────────────────────────────────────────────────
# Internal integration token (https://www.notion.so/my-integrations).
# Share your target page(s) with the integration before ingesting.
NOTION_TOKEN=
# Root Notion page to ingest. Either a 32-char page id (with or without dashes)
# or a full https://www.notion.so/... URL.
NOTION_PAGE_URL=
NOTION_MAX_DEPTH=3

# ─── ASR / transcription ──────────────────────────────────────────────────────
# asr: groq (default, fast + free) | local (offline, slower)
ASR_PROVIDER=groq
# Free at https://console.groq.com — needed only when ASR_PROVIDER=groq.
GROQ_API_KEY=

# ─── Answer LLM (MiniMax) ────────────────────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_MODEL=M2.7
MINIMAX_BASE_URL=https://api.MiniMax.com/v1

# ─── Embeddings ────────────────────────────────────────────────────────────────
# Default: intfloat/multilingual-e5-small (384-dim, ~470MB, en/hi/te).
EMBED_MODEL=intfloat/multilingual-e5-small
# Optional: pre-download the model on `make install` (skipped if already cached).
EMBED_PRELOAD=0

# ─── Retrieval ─────────────────────────────────────────────────────────────────
# Optional: extra precision at the cost of latency. Off by default.
ENABLE_LLM_RERANK=0

# ─── App ──────────────────────────────────────────────────────────────────────
# Optional single-password gate for the local UI. Leave blank to disable.
APP_PASSWORD=
# SQLite file path (relative to repo root by default).
DB_PATH=./data/askmynotion.db
# HTTP bind.
HOST=127.0.0.1
PORT=8000
# 1 = enable public Notion link reader (best-effort, token mode is still primary).
ENABLE_PUBLIC_NOTION_READER=1
# Disable ALL Instagram fetching (transcript-only mode). 1 = off, 0 = on.
DISABLE_INSTAGRAM_FETCH=0
# Log level
LOG_LEVEL=INFO
